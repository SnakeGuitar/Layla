@inherits LayoutComponentBase

<!-- 
    DESKTOP (lg+): Layout en "L"
    - Columna izquierda fija: "Layla" arriba + Navbar debajo
    - Columna derecha: Header "About" arriba fijo + contenido

    MÓVIL/TABLET (<lg):
    - Barra superior fija: "Layla" a la izquierda + botón hamburguesa a la derecha
    - Navbar desplegable debajo de la barra
    - Header "About" debajo del navbar
    - Contenido de la página
-->

<div class="lg:flex lg:h-screen lg:overflow-hidden">

    <!-- ═══════════════════════════════════════════
         SIDEBAR — visible en desktop como columna izquierda
         En móvil se colapsa dentro del NavMenu
    ═══════════════════════════════════════════ -->
    <aside class="lg:w-64 lg:shrink-0 lg:flex lg:flex-col lg:h-screen lg:overflow-y-auto lg:sticky lg:top-0">
        <NavMenu />
    </aside>

    <!-- ═══════════════════════════════════════════
         COLUMNA DERECHA: header + contenido
    ═══════════════════════════════════════════ -->
    <div class="flex-1 flex flex-col lg:overflow-y-auto lg:h-screen">

        <!-- Header "About" — sticky en desktop, sigue al navbar en móvil -->
        <header class="
            lg:sticky lg:top-0 lg:z-30
            px-6 sm:px-8 h-14 min-h-14
            bg-linear-to-r from-base-blue-3 to-base-purple-1
            border-b border-white/10
            flex items-center justify-end
            shadow-sm
        ">
            <a
                href="https://learn.microsoft.com/aspnet/core/"
                target="_blank"
                class="text-white/70 text-sm font-medium tracking-wide no-underline hover:text-white hover:underline transition-colors duration-200">
                About
            </a>
        </header>

        <!-- Contenido principal -->
        <main class="flex-1">
            <article class="content bg-base-gray-1 px-6 py-6">
                @Body
            </article>
        </main>

    </div>
</div>
