@page "/projects/my-projects"
@using client_web.Components.Components

@* Header *@
<header class="max-w-5xl mx-auto mb-12">
    <h2 class="text-amber-500 text-xs font-bold tracking-[0.3em] uppercase mb-3">Projects</h2>
    <h1 class="text-stone-100 font-serif text-4xl md:text-5xl font-light tracking-tight">
        My Projects
    </h1>
    <div class="mt-4 w-16 h-px bg-amber-500"></div>
</header>

@if (projects == null || !projects.Any())
    {
        <p class="text-stone-500 text-sm">No projects have been created yet.</p>
    }
    else
    {
        <div class="grid md:grid-cols-2 sm:grid-cols-1 gap-1 bg-transparent">
            @foreach (ProjectViewModel project in projects)
            {
                <div>
                    <ProjectCard2 Id="@project.Id" Title="@project.Title"
                                    Synopsis="@project.Synopsis"
                                    LiteraryGenre="@project.LiteraryGenre"
                                    CoverImageUrl="@project.CoverImageUrl"
                                    UpdatedAt="@project.UpdatedAt"
                                    OnCardClick="HandleCardClick" />
                </div>
            }
        </div>
    }

