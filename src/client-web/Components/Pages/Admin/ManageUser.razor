@page "/admin/manage-users"
@inject IJSRuntime JS

<header class="max-w-5xl mx-auto mb-12">
    <h2 class="text-amber-500 text-xs font-bold tracking-[0.3em] uppercase mb-3">Administración</h2>
    <h1 class="text-stone-100 font-serif text-4xl md:text-5xl font-light tracking-tight">
        Gestión de usuario
    </h1>
    <div class="mt-4 w-16 h-px bg-amber-500"></div>
</header>

<section>
    <div>
        <input type="search"
    </div>
</section>

<main>
    <div>
        @if ( users == null || !users.Any()) {
            <div>Use la sección de filtros</div>
        }else{
            <table>
                <thead>
                    <tr>
                        <th>UID</th>
                        <th>Nombre completo</th>
                        <th>Género</th>
                        <th>Fecha última actividad</th>
                        <th>Con actividad este mes</th>
                        <th>Fecha de registro</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (UserViewModel user in users) {
                        <tr>
                            <td>@user.UserId</td>
                            <td>@user.FullName</td>
                            <td>@user.Genre</td>
                            <td>@user.LastActivity</td>
                            <td>@user.WithActivityThisMonth</td>
                            <td>@user.RegisteredAt</td>>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div
</main>


